# Example nginx site config for Mayhem Tracker.
# Copy to /etc/nginx/sites-available/mayhem-tracker, edit the domain, then:
#   sudo ln -s /etc/nginx/sites-available/mayhem-tracker /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d your.domain.com   (sets up TLS and rewrites this file)
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name your.domain.com;

    # Optional: shared login so the dashboard isn't fully public.
    # Generate with: sudo apt install apache2-utils && sudo htpasswd -c /etc/nginx/mayhem.htpasswd mayhem
    # auth_basic "Mayhem Tracker";
    # auth_basic_user_file /etc/nginx/mayhem.htpasswd;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
